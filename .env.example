# ─── Server ───────────────────────────────────────────────
NODE_ENV=production
PORT=8080

# ─── Site URL (used for canonical, OG tags, sitemap) ──────
SITE_URL=https://your-domain.com

# ─── Database (DigitalOcean PostgreSQL) ───────────────────
# Leave empty to use JSON file fallback (local dev)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── AI Article Generation ────────────────────────────────
# Set to "true" to enable cron-based article generation
AUTO_GEN_ENABLED=false
OPENAI_API_KEY=sk-...
# Or use DeepSeek
# DEEPSEEK_API_KEY=sk-...

# ─── Amazon Associates ────────────────────────────────────
AMAZON_AFFILIATE_TAG=movingabroad-20

# ─── Bunny CDN ────────────────────────────────────────────
# Leave empty to use Unsplash images (default)
BUNNY_STORAGE_ZONE=your-storage-zone
BUNNY_API_KEY=your-bunny-api-key
BUNNY_CDN_URL=https://your-zone.b-cdn.net
